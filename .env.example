# Neon Postgres connection string (from the Vercel Neon integration, or your own Neon project)
DATABASE_URL=

# Generate with: npx auth secret
AUTH_SECRET=

# Google OAuth credentials (Google Cloud Console > APIs & Services > Credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated allowlist of emails permitted to manage items (add/edit/
# delete/mark lent). Optional; defaults to the owner's email.
OWNER_EMAIL=
